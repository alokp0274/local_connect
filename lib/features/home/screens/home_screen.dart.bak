                  child: EcosystemProviderRail(
                    title: 'Trusted by Families Nearby',
                    subtitle: '',
                    items: _ecosystem.trustedByFamilies,
                    onTapItem: _openProviderDetail,
                    accentColor: AppTheme.accentBlue,
                  ),
                ),
                SliverToBoxAdapter(
                  child: EcosystemProviderRail(
                    title: 'Fastest Responders',
                    subtitle: '',
                    items: _ecosystem.fastestResponders,
                    onTapItem: _openProviderDetail,
                    accentColor: AppTheme.accentCoral,
                  ),
                ),
                SliverToBoxAdapter(
                  child: RetentionSection(
                    reconnectProvider: _ecosystem.reconnectSuggestion,
                    recentlyContacted: _ecosystem.recentlyContacted,
                    onTapProvider: _openProviderDetail,
                    onReconnect: () {
                      final p = _ecosystem.reconnectSuggestion;
                      if (p != null) _makeCall(p.phone);
                    },
                  ),
                ),
                SliverToBoxAdapter(
                  child: EcosystemProviderRail(
                    title: 'Popular This Week in $_currentPincode',
                    subtitle: '',
