                  child: EcosystemProviderRail(
                    title: 'Top Rated in $_currentPincode',
                    subtitle: '',
                    items: _ecosystem.topRated,
                    onTapItem: _openProviderDetail,
                    onSeeAll: () => _openMicroZone('Top Rated'),
                    accentColor: AppTheme.accentGold,
                  ),
                ),
                SliverToBoxAdapter(
                  child: Padding(
                    padding: const EdgeInsets.only(top: 8, bottom: 4),
                    child: LocalTrustBar(
                      pincode: _currentPincode,
                      totalProviders: _ecosystem.totalAvailable,
                      onlineCount: _ecosystem.onlineCount,
                    ),
                  ),
                ),
                SliverToBoxAdapter(
                  child: EcosystemProviderRail(
                    title: '${_ecosystem.onlineCount} Available Now',
                    subtitle: '',
